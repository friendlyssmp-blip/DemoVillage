rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidVillage(data) {
      return data.userId is string
          && data.resources is map 
          && data.maxCapacity is map
          && data.lastActive is number;
    }

    match /villages/{villageId} {
      allow read: if isSignedIn();
      allow write: if isOwner(villageId);
    }

    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /usernames/{username} {
      allow get: if true;
      allow write: if isSignedIn()
        && (resource == null || resource.data.uid == request.auth.uid)
        && incoming().uid == request.auth.uid;
    }

    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && incoming().leaderId == request.auth.uid;
      allow update: if isSignedIn() && (
        isOwner(existing().leaderId) || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['memberCount']) && incoming().memberCount == existing().memberCount + 1)
      );
    }

    match /clans/{clanId}/members/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /chats/global/messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && incoming().senderId == request.auth.uid
        && incoming().timestamp == request.time.toMillis();
    }

    match /users/{userId}/dailyRewards/{document} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/friendRequests/{reqId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow update: if isOwner(userId) && incoming().status in ['accepted', 'declined'];
      allow delete: if isOwner(userId) || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/users/$(userId)/friendRequests/$(reqId)).data.fromId);
    }

    match /users/{userId}/friends/{friendId} {
      allow read: if isOwner(userId);
      // Allow adding a friend if the user is the owner, OR if the request is mutual (though mutual is hard to check without a backend, I will allow create if sender and receiver agree?)
      // Simplest: Each side adds the other. My current batch logic fails because it tries to add on behalf of the other.
      allow create, delete: if isOwner(userId) || isOwner(friendId); 
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
