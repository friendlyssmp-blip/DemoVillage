rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      
      match /profile {
         // Users can only create/update their own profile
         allow read: if isSignedIn();
         allow write: if isOwner(userId) && isVerified();
      }
      
      match /friends/{friendId} {
         allow read: if isOwner(userId);
         allow write: if isOwner(userId);
      }
      
      match /friendRequests/{requestId} {
         allow read: if isOwner(userId) || isOwner(incoming().senderId);
         allow create: if isSignedIn() && incoming().targetUserId == userId;
         allow update, delete: if isOwner(userId);
      }
    }

    // --- Villages (The Main Game Data) ---
    match /villages/{userId} {
      allow read: if isSignedIn();
      
      // Strict validation for the "latest" game state
      function isValidVillage(data) {
        return data.keys().hasAll(['userId', 'latest', 'lastSynced'])
          && data.userId == request.auth.uid
          && data.latest.resources.wood is number
          && data.latest.resources.wood >= 0
          && data.latest.buildings is list;
      }

      allow create: if isOwner(userId) && isVerified() && isValidVillage(incoming());
      
      allow update: if isOwner(userId) && isVerified() && isValidVillage(incoming()) && (
        // Action: Standard Sync
        incoming().diff(existing()).affectedKeys().hasOnly(['latest', 'fallback', 'lastSynced'])
      );
    }

    // --- Clans ---
    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isVerified();
      allow update: if isSignedIn(); // Add more complexity for leadership later
      
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isOwner(memberId);
      }
    }

    // --- Chat ---
    match /messages_global/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isVerified() && incoming().senderId == request.auth.uid;
    }

    match /messages_clan_{clanId}/{msgId} {
      allow read: if isSignedIn(); // Add clan membership check for production
      allow create: if isSignedIn() && isVerified() && incoming().senderId == request.auth.uid;
    }
  }
}
