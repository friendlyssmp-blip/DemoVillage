rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL SAFETY NET ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- ENTITY VALIDATION BLUEPRINTS ---
    function isValidVillage(data) {
      return data.keys().hasAll(['userId', 'buildings', 'resources', 'era', 'npcsCount', 'lastSynced'])
          && data.userId == request.auth.uid
          && data.buildings is list
          && data.resources is map
          && data.era is string
          && data.lastSynced == request.time;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['username', 'joinedAt'])
          && data.username is string && data.username.size() <= 32
          && data.joinedAt is number;
    }

    function isJoinClanAction() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['memberCount'])
          && incoming().memberCount == existing().memberCount + 1;
    }

    // --- COLLECTIONS ---

    match /villages/{villageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Secure list query
      allow create: if isOwner(villageId) && isValidVillage(incoming());
      allow update: if isOwner(villageId) && isValidVillage(incoming())
                   && incoming().userId == existing().userId; // Immutable userId
    }

    match /profiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Search allowed but limited by query in code
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isOwner(userId) && isValidProfile(incoming())
                   && !incoming().diff(existing()).affectedKeys().hasAny(['roles', 'isAdmin']); // Protect roles
    }

    match /usernames/{username} {
      allow get: if true;
      allow write: if isOwner(incoming().uid) 
                   && (resource == null || existing().uid == request.auth.uid)
                   && isValidId(username);
    }

    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().leaderId == request.auth.uid;
      allow update: if isSignedIn() && (
        isOwner(existing().leaderId) || 
        isJoinClanAction()
      );
    }

    match /clans/{clanId}/members/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /clans/{clanId}/messages/{msgId} {
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid));
      allow create: if isSignedIn() 
        && incoming().senderId == request.auth.uid
        && exists(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid))
        && incoming().timestamp <= request.time.toMillis();
    }

    match /chats/global/messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && incoming().senderId == request.auth.uid
        && incoming().timestamp <= request.time.toMillis(); // Changed == to <= for client tolerance
    }

    match /users/{userId}/dailyRewards/{document} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/friendRequests/{reqId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow update: if isOwner(userId) && incoming().status in ['accepted', 'declined'];
      allow delete: if isOwner(userId) || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/users/$(userId)/friendRequests/$(reqId)).data.fromId);
    }

    match /users/{userId}/friends/{friendId} {
      allow read: if isOwner(userId);
      allow create, delete: if isOwner(userId) || isOwner(friendId); 
    }

  }
}
